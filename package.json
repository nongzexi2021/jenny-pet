{
  "name": "jenny-pet",
  "version": "1.0.0",
  "description": "Jenny的专属桌面小伙伴 💕",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^28.3.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.jenny.desktop-pet",
    "productName": "Jenny的小伙伴",
    "files": ["main.js", "preload.js", "pet_final.html"],
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        { "target": "dmg", "arch": ["arm64"] }
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Jenny的小伙伴需要麦克风来录语音备忘录和语音聊天 🎤",
        "NSLocationUsageDescription": "Jenny的小伙伴想根据你的位置显示天气 ☀️"
      }
    },
    "dmg": {
      "title": "Jenny的小伙伴"
    }
  }
}
